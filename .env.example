# Copy to .env for local dev or Docker Compose:
#   cp .env.example .env

# HTTP port (host port when using Docker Compose)
PORT=3000

# development | production
NODE_ENV=development

# Required in production (min 16 characters). If unset, a random secret is used
# on each restart and all login sessions are invalidated.
# SESSION_SECRET=replace-with-a-long-random-string

# Credentials for importing legacy data/characters/*.json on first DB init
LEGACY_ACCOUNT_USERNAME=legacy
LEGACY_ACCOUNT_PASSWORD=legacy

# Gameplay debug log (movement, pathfinding, session events)
# DEBUG_EVENTS=1
# DEBUG_LOG_FILE=data/debug-events.log
# DEBUG_LOG_MAX_BYTES=5242880
# DEBUG_LOG_MAX_FILES=5

# Local Ollama quest generation (per-player procedural quests)
# OLLAMA_ENABLED=1
# Local Node (`npm start`): http://127.0.0.1:11434
# Docker Compose uses network_mode: host, so the container also uses 127.0.0.1 for Ollama.
# DOCKER_OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=mmo001-quests
# OLLAMA_TIMEOUT_MS=180000
# QUEST_GEN_COOLDOWN_MS=60000
# QUEST_GEN_MAX_ACTIVE=3
# Quest generation audit log (JSON lines; on by default; lives under data/)
# QUEST_GEN_LOG=1
# QUEST_GEN_LOG_FILE=data/quest-generation.log
# QUEST_GEN_LOG_MAX_BYTES=5242880
# QUEST_GEN_LOG_MAX_FILES=5
